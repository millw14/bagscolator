# Solana RPC endpoint (use a private RPC for production)
RPC_URL=https://api.devnet.solana.com

# Path to the keeper's keypair file (pays tx fees, gets WSOL rent refunded)
KEEPER_KEYPAIR_PATH=~/.config/solana/id.json

# Bagscolator program ID (update after `anchor keys list`)
PROGRAM_ID=Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS

# Config PDA address for the specific token launch being monitored
CONFIG_ADDRESS=

# Jupiter v6 API base URL
JUPITER_API_URL=https://quote-api.jup.ag/v6

# Polling interval in milliseconds
POLL_INTERVAL_MS=15000

# Max retries on transient errors before backing off
MAX_RETRIES=3

# Jitter range (ms) added to execution timing to reduce front-run predictability
JITTER_MAX_MS=5000
